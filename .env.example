# RabbitMQ connection
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_QUEUE=sys_error.queue

# Output queues and exchanges
OUTPUT_TELEGRAM_QUEUE=output_telegram.queue
OUTPUT_TELEGRAM_EXCHANGE=output_telegram.events
OUTPUT_TELEGRAM_ROUTING_KEY=output_telegram.events

OUTPUT_EMAIL_QUEUE=output_email.queue
OUTPUT_EMAIL_EXCHANGE=output_email.events
OUTPUT_EMAIL_ROUTING_KEY=output_email.events

OUTPUT_SLACK_QUEUE=output_slack.queue
OUTPUT_SLACK_EXCHANGE=output_slack.events
OUTPUT_SLACK_ROUTING_KEY=output_slack.events

# Logging
LOG_DIR=./logs
LOG_FILE_PREFIX=sys_error

# Retry delay (seconds)
RETRY_DELAY=60
